{
  "name": "digital-accelerator-theme",
  "private": true,
  "scripts": {
    "postinstall": "node scripts/copy-vendors.js",
    "copy-vendors": "node scripts/copy-vendors.js",
    "copy-bootstrap": "node scripts/copy-vendors.js",
    "build:css": "sass assets/scss/main.scss assets/css/main.css --style=expanded --source-map && sass assets/scss/custom.scss assets/css/custom.css --style=expanded --source-map",
    "watch:css": "sass --watch assets/scss/main.scss:assets/css/main.css assets/scss/custom.scss:assets/css/custom.css --style=expanded --source-map"
  },
  "dependencies": {
    "bootstrap": "^5.3.6",
    "swiper": "^11.2.6"
  },
  "devDependencies": {
    "sass": "^1.83.0"
  }
}
